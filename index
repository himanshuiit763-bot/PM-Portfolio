            background-image: radial-gradient(#CBD5E1 0.5px, transparent 0.5px);
            background-size: 24px 24px;
            opacity: 0.3;
            z-index: -1;
        }

        .container-box {
            max-width: 1000px;
            margin: 0 auto;
            background: #FFFFFF;
            box-shadow: 0 10px 50px -12px rgba(0, 0, 0, 0.08);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #E2E8F0;
            margin-top: 2rem;
            margin-bottom: 4rem;
        }

        .hero {
            padding: 4rem 3rem 2rem;
            background: linear-gradient(to bottom right, #FFFFFF, #F1F5F9);
            border-bottom: 1px solid #F1F5F9;
        }

        .hero h1 {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 900;
            color: var(--brand-blue);
            line-height: 1.1;
        }

        .hero h1 span {
            color: var(--brand-gold);
        }

        .resume-btn {
            background: var(--brand-blue);
            color: white !important;
            padding: 12px 28px;
            border-radius: 8px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .resume-btn:hover {
            background: #000;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
        }

        .case-card {
            padding: 1.5rem;
            border-radius: 10px;
            border: 1px solid #E2E8F0;
            transition: all 0.3s ease;
            cursor: pointer;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .case-card:hover {
            transform: translateY(-4px);
            border-color: var(--link-color);
            box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.15);
        }

        .pill {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 3px 8px;
            border-radius: 4px;
            background: #F1F5F9;
            color: var(--text-muted);
        }

        .pill-highlight {
            background: #DBEAFE;
            color: #1E40AF;
        }

        .skill-tag {
            background: #F8FAFC;
            border: 1px solid #E2E8F0;
            padding: 2px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        @media (max-width: 768px) {
            .hero { padding: 2rem 1.5rem; }
            .hero h1 { font-size: 2.5rem; }
            .container-box { margin: 0; border-radius: 0; }
